{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/index", "destination": "/index.html" },
    { "source": "/index.html", "destination": "/index.html" },
    { "source": "/general-vision", "destination": "/general-vision.html" },
    { "source": "/general-vision.html", "destination": "/general-vision.html" },
    { "source": "/biovision", "destination": "/biovision.html" },
    { "source": "/biovision.html", "destination": "/biovision.html" },
    { "source": "/geospatial-analysis", "destination": "/geospatial-analysis.html" },
    { "source": "/geospatial-analysis.html", "destination": "/geospatial-analysis.html" },
    { "source": "/workspace", "destination": "/workspace.html" },
    { "source": "/workspace.html", "destination": "/workspace.html" },
    { "source": "/css/:path*", "destination": "/frontend/css/:path*" },
    { "source": "/js/:path*", "destination": "/frontend/js/:path*" },
    { "source": "/frontend/:path*", "destination": "/frontend/:path*" }
  ]
}
