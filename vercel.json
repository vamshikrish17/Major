{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/index", "destination": "/frontend/index.html" },
    { "source": "/general-vision", "destination": "/frontend/general-vision.html" },
    { "source": "/biovision", "destination": "/frontend/biovision.html" },
    { "source": "/geospatial-analysis", "destination": "/frontend/geospatial-analysis.html" },
    { "source": "/workspace", "destination": "/frontend/workspace.html" },
    { "source": "/css/:path*", "destination": "/frontend/css/:path*" },
    { "source": "/js/:path*", "destination": "/frontend/js/:path*" }
  ]
}
